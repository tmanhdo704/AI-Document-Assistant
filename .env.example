# Application
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

# PostgreSQL - development values only
POSTGRES_DB=ai_document_assistant
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://app:change-me@localhost:5432/ai_document_assistant

# Authentication - replace before implementing authentication
JWT_SECRET_KEY=replace-with-a-long-random-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI services - introduced in week 3
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=document_chunks
LLM_API_KEY=
EMBEDDING_API_KEY=

# Usage limits
GUEST_MAX_DOCUMENTS=1
GUEST_MAX_QUESTIONS=3
GUEST_MAX_FILE_SIZE_MB=10
GUEST_MAX_PAGES=30
GUEST_SESSION_EXPIRE_MINUTES=30
USER_MAX_DOCUMENTS=10
USER_MAX_QUESTIONS_PER_DAY=100
USER_MAX_FILE_SIZE_MB=20
USER_MAX_PAGES=200
